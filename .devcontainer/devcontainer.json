// For format details, see https://aka.ms/devcontainer.json
// For available features, see https://github.com/devcontainers/features
{
	"name": "React & Node.js (TypeScript)",
	"build": {
		"dockerfile": "Dockerfile",
		// Update 'VARIANT' to pick a Node.js version (use even numbers for LTS): 22, 20, 18
		"args": {
			"VARIANT": "20-bookworm"
		}
	},

	// Forward the default React dev-server port.
	"forwardPorts": [3000],

	// CHOKIDAR_USEPOLLING is required for file-watch events to work inside Docker on
	// macOS and Windows hosts, where inotify cannot cross the VM boundary.
	"remoteEnv": { "CHOKIDAR_USEPOLLING": "true" },

	// Run as the non-root 'node' user for least-privilege inside the container.
	"remoteUser": "node",

	// Use the current devcontainer spec key names.
	// The legacy top-level 'settings' and 'extensions' keys were removed in VS Code 1.77.
	"customizations": {
		"vscode": {
			"settings": {
				"terminal.integrated.defaultProfile.linux": "zsh",
				"files.trimTrailingWhitespace": true,
				"editor.formatOnSave": true,
				"editor.codeActionsOnSave": {
					"source.fixAll.eslint": "explicit"
				}
			},
			"extensions": [
				"dbaeumer.vscode-eslint",
				"esbenp.prettier-vscode",
				"dsznajder.es7-react-js-snippets",
				"formulahendry.auto-rename-tag",
				"christian-kohler.path-intellisense",
				"streetsidesoftware.code-spell-checker",
				"VisualStudioExptTeam.vscodeintellicode",
				"mhutchie.git-graph",
				"ms-vscode.vscode-typescript-next"
			]
		}
	}

	// Uncomment to run commands after the container is created.
	// "postCreateCommand": "npm install"
}
